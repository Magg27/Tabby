{
  "schemaVersion": 1,
  "id": "tabby",
  "version": "${version}",

  "name": "Tabby",
  "description": "Tabby is a highly customisable Fabric mod for Minecraft that adds extra utility to the tab list",
  "authors": [
    {
      "name": "Magg27",
      "contact": {
        "discord": "maggr"
      }
    }
  ],
  "contributors": [
    { "name": "Fruitloopins" }
  ],
  "contact": {
    "homepage": "https://github.com/Fruitloopins",
    "sources": "https://github.com/Fruitloopins/Tabby",
    "issues" : "https://github.com/Fruitloopins/Tabby/issues"
  },

    "license": "GPL",
  "icon": "assets/tabby/icon.png",

  "environment": "client",
  "entrypoints": {
    "client": [
      "com.fwloopins.tabby.client.TabbyClient"
    ],
    "modmenu": [
      "com.fwloopins.tabby.client.config.ModMenuIntegration"
    ]
  },
  "mixins": [
    "tabby.mixins.json"
  ],

  "depends": {
    "fabricloader": ">=0.18.4",
    "fabric-api": "*",
    "minecraft": "~1.21.11",
    "java": ">=21"
  },
  "custom": {
    "modmenu": {
      "links": {
        "Discord": "https://discord.gg/ey6ZvnwAJp"
      }
    }
  }
}
